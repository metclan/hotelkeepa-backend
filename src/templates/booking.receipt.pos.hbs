<html>
  <head>
    <meta charset="UTF-8" />
    <title>Booking Receipt</title>

    <style>
      * {
        box-sizing: border-box;
      }

      @page {
        size: 80mm auto;
        margin: 0;
      }

      body {
        margin: 0;
        padding: 0;
        background: #fff;
        color: #000;
        font-family: "Courier New", monospace;
        font-size: 12px;
        font-weight: 600;
        line-height: 1.35;
        -webkit-font-smoothing: none;
        text-rendering: geometricPrecision;
      }

      .receipt {
        width: 80mm;
        padding: 4mm;
        color: #000;
      }

      .center {
        text-align: center;
      }

      .bold {
        font-weight: 800;
      }

      .line {
        border-top: 2px dashed #000;
        margin: 8px 0;
      }

      .row {
        display: flex;
        justify-content: space-between;
        gap: 8px;
        margin: 3px 0;
      }

      .label {
        flex: 1;
      }

      .value {
        flex: 1;
        text-align: right;
        word-break: break-word;
      }

      .hotel-name {
        font-size: 16px;
        font-weight: 900;
        text-transform: uppercase;
      }

      .title {
        font-size: 14px;
        font-weight: 900;
        margin-top: 8px;
      }

      .room-header,
      .room-row {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 4px;
        margin: 3px 0;
      }

      .room-header {
        font-weight: 900;
        border-bottom: 1px solid #000;
        padding-bottom: 2px;
      }

      .right {
        text-align: right;
      }

      .footer {
        margin-top: 10px;
        text-align: center;
        font-weight: 900;
      }

      .no-print {
        margin: 12px 4mm;
        border: 2px solid #000;
        background: #000;
        color: #fff;
        font-family: Arial, sans-serif;
        font-size: 14px;
        font-weight: 700;
        padding: 8px 12px;
        cursor: pointer;
      }

      @media print {
        body {
          width: 80mm;
          font-weight: 700;
          print-color-adjust: exact;
          -webkit-print-color-adjust: exact;
        }

        .receipt {
          width: 80mm;
          padding: 3mm;
        }

        .no-print {
          display: none;
        }
      }
    </style>
  </head>

  <body>
    <div class="receipt">

      <div class="center">
        <div class="hotel-name">{{companyName}}</div>
        <div>{{companyAddress}}</div>
        <div>{{companyPhone}}</div>
      </div>

      <div class="line"></div>

      <div class="center title">BOOKING RECEIPT</div>

      <div class="line"></div>

      <div class="row">
        <div class="label">Booked By</div>
        <div class="value">{{bookedBy}}</div>
      </div>

      <div class="row">
        <div class="label">Booking No</div>
        <div class="value">{{bookingNumber}}</div>
      </div>

      <div class="row">
        <div class="label">Booking Date</div>
        <div class="value">{{bookingDate}}</div>
      </div>

      <div class="line"></div>

      <div class="row">
        <div class="label">Guest</div>
        <div class="value">{{guestName}}</div>
      </div>

      <div class="row">
        <div class="label">Phone</div>
        <div class="value">{{guestPhone}}</div>
      </div>

      <div class="line"></div>

      <div class="row">
        <div class="label">Arrival</div>
        <div class="value">{{arrivalDate}}</div>
      </div>

      <div class="row">
        <div class="label">Departure</div>
        <div class="value">{{departureDate}}</div>
      </div>

      <div class="row">
        <div class="label">Nights</div>
        <div class="value">{{numberOfNights}}</div>
      </div>

      <div class="line"></div>

      <div class="room-header">
        <div>ROOM</div>
        <div class="right">RATE</div>
        <div class="right">AMOUNT</div>
      </div>

      {{#each rooms}}
        <div class="room-row">
          <div>{{roomNumber}}</div>
          <div class="right">{{rate}}</div>
          <div class="right">{{amount}}</div>
        </div>
      {{/each}}

      <div class="line"></div>

      <div class="row bold">
        <div class="label">Total</div>
        <div class="value">{{totalAmount}}</div>
      </div>

      <div class="row">
        <div class="label">Paid</div>
        <div class="value">{{amountPaid}}</div>
      </div>

      <div class="row">
        <div class="label">Balance</div>
        <div class="value">{{balance}}</div>
      </div>

      <div class="row">
        <div class="label">Payment</div>
        <div class="value">{{paymentMethod}}</div>
      </div>

      <div class="line"></div>

      <div class="footer">
        THANK YOU
      </div>

    </div>

    <button class="no-print" onclick="window.print()">Print Receipt</button>
  </body>
</html>