// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(uuid())
  name         String         @db.Text
  email         String         @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  emailVerified Boolean        @default(false)
  isActive      Boolean        @default(true)
  onboardingStage Int       @default(1)
  isOwner       Boolean        @default(false)
  phone         String?
  roleId        String?
  locationId    String?
  businessId    String?
  image         String?        @db.Text

  // Relationships
  role  Role? @relation(fields: [roleId], references: [id])
  businessLocation Location? @relation(fields: [locationId], references: [id])
  business         Business? @relation(fields: [businessId], references: [id])
  reservations     Reservation[]
  sessions      Session[]
  accounts      Account[]
  invitations   Invitation[]

  @@map("user")
  
}

model Business {
  id String @id @default(uuid())
  name    String?
  locations Location[]
  currencyId             String?
  countryId              String?

  // Realationships
  subscriptions Subscription[]
  subscriptinoPayments SubscriptionPayment[]
  users         User[]
  currency               Currency?                 @relation(fields: [currencyId], references: [id])
  country                Country?                @relation(fields: [countryId], references: [id])

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}
model Role {
  id String @id @default(uuid())
  name    String
  isAdmin Boolean @default(false)
  locationId String

  // Relations 
  businessLocation Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  rolePermissions  RolePermission[]
  users       User[]
  invitations Invitation[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}
model PermissionGroup {
  id String @id @default(uuid())
  name    String
  code    String @unique
  description String

  // Relationships
  permissions Permission[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}
model Permission { 
  id String @id @default(uuid())
  code    String @unique
  name    String
  permissionGroupId String
  rolePermissions RolePermission[]
  
  // Relationship 
  permissionGroup PermissionGroup @relation(fields: [permissionGroupId], references: [id], onDelete: Cascade)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model RolePermission { 
  id String @id @default(uuid())
  roleId  String
  permissionId  String

  // Relationships
  role  Role @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([roleId, permissionId])
}
model Location {
  id String @id @default(uuid())
  name       String?
  address    String?
  city       String?
  state      String?
  zip        String?
  phone      String?
  email      String?
  isActive   Boolean @default(true)
  isDeleted  Boolean @default(false)
  businessId String


  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  rooms    Room[]
  roles    Role[]
  users    User[]
  subscriptionPayments SubscriptionPayment[]
  subscriptions Subscription[]
  documentSequences DocumentSequence[]
  reservations  Reservation[]
  customers Customer[]
  roomTypes RoomType[]
  payments  Payment[]
  customLabels           CustomLabels[]
  invitations   Invitation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Constraints 
  @@unique([businessId, name])
}
model CustomLabels {
  id String @id @default(uuid())
  locationId         String
  label              String              @db.VarChar(255)
  type               CustomLabelType
  location           Location            @relation(fields: [locationId], references: [id], onDelete: Cascade)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @default(now()) @updatedAt

  paymentMethods    PaymentMethodEntry[]
}
enum CustomLabelType {
  payment
}
model Room {
  id String @id @default(uuid())
  roomNumber         String
  roomTypeId   String
  floor        String?
  locationId   String
  status       RoomStatus @default(available)
  roomType   RoomType   @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  // Relations 
  roomLocation Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  reservationLines  ReservationLine[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([locationId, roomNumber])
}
model RoomType {
  id String @id @default(uuid())
  name         String
  locationId   String
  pricePerNight Decimal @db.Decimal(10,2)
  description  String?
  maxAdults     Int?
  maxChildren   Int?
  maxOccupancy  Int?
  
  // Relations
  roomTypeLocation Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  rooms  Room[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}
model Customer { 
  id String @id @default(uuid())
  firstName String
  lastName  String? 
  phone     String
  email     String?
  locationId  String
  address   String? 
  gender    Gender? 
  idType    String? 
  idNumber  String? 
  nationality String? 
  occupation  String? 
  dateOfBirth DateTime?
  isActive    Boolean @default(true)
  isDeleted   Boolean @default(false)

  // Relationships
  location  Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  reservations  Reservation[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
}
model Reservation {
  id String @id @default(uuid())
  customerId  String
  locationId  String
  userId     String
  reservationDate DateTime
  arrivalDate     DateTime
  departureDate   DateTime
  totalAmount Decimal @db.Decimal(10,2)
  bookingNumber String?
  paymentStatus PaymentStatus
  notes      String?

  // Relationships
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservationLines  ReservationLine[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}
model ReservationLine {
  id String @id @default(uuid())
  reservationId String 
  roomId        String
  checkInDate   DateTime?
  checkOutDate  DateTime?
  numberOfAdults Int?
  numberOfChildren Int?
  pricePerNight Decimal @db.Decimal(10,2)
  status        ReservationRoomStatus? @default(reserved)

  // Relationships
  room          Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}
model Payment {
  id String @id @default(uuid())
  locationId  String
  contactType ContactType
  contactId   String? // refers to Patient/Supplier/etc
  direction   PaymentDirection
  amount      Decimal             @db.Decimal(10, 2)
  paymentDate DateTime
  reference   String?
  notes       String?
  createdById String

  // Relationships
  locations Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  allocations PaymentAllocation[]
  paymentMethods  PaymentMethodEntry[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  
}

model PaymentMethodEntry {
  id String @id @default(uuid())
  paymentId       String 
  paymentMethodId String 
  amount          Decimal          @db.Decimal(10,2)
  payment         Payment          @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  customLabels    CustomLabels @relation(fields: [paymentMethodId], references: [id])
  @@unique([paymentId, paymentMethodId])
}

model PaymentAllocation {
  id String @id @default(uuid())
  paymentId       String
  transactionType TransactionType
  transactionId   String? 
  amountApplied   Decimal         @db.Decimal(10, 2)
  allocationType  AllocactionType
  payment         Payment         @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

model DocumentSequence {
  id String @id @default(uuid())
  locationId  String 
  transactionType DocumentType
  currentNumber   Int @default(0)

  // Relationship
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([locationId, transactionType])
}
model Plan {
  id String @id @default(uuid())
  name         String
  price        Float
  maxUsers     Int?
  maxLocations Int?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id String @id @default(uuid())
  businessId String
  planId     String
  startDate  DateTime
  endDate    DateTime?
  locationId String?

  // Relations
  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  plan     Plan      @relation(fields: [planId], references: [id])
  location Location? @relation(fields: [locationId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  subcriptionPayments  SubscriptionPayment[]
}

model SubscriptionPayment {
  id String @id @default(uuid())
  subscriptionId    String
  amount            Int
  paidAt            DateTime
  provider          String?
  providerReference String?
  locationId        String?
  status            SubscriptionPaymentStatus @default(PENDING)
  businessId        String

  // Relations
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location     Location?    @relation(fields: [locationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
enum SubscriptionPaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?  @db.Text
  userAgent String?  @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId(length: 191)])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String    @db.Text
  providerId            String    @db.Text
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?   @db.Text
  password              String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId(length: 191)], map: "account_userId_idx_new")
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String   @db.Text
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier(length: 191)])
  @@map("verification")
}

model Country {
  id String @id @default(uuid())
  name       String     @unique
  code       String     @unique
  phoneCode  String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  businesses Business[]
  currency Currency?
}
model Currency {
  id String @id @default(uuid())
  code       String     @unique
  name       String
  symbol     String
  countryId  String?    @unique
  shortForm  String     @unique
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  businesses Business[]
  country    Country?    @relation(fields: [countryId], references: [id])
}
model Invitation {
  id String @id @default(uuid())
  email String 
  name String
  token String @unique
  roleId  String 
  locationId  String
  businessId  String 
  invitedById String 
  status  InviteStatus @default(pending)
  expiresAt DateTime
  acceptedAt  DateTime? 

  // Relationships 
  role  Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  invitedBy User @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
enum InviteStatus { 
  pending 
  accepted 
  expired 
  revoked
}
enum RoomStatus {
  available
  occupied
  reserved
  maintenance
}
enum ReservationRoomStatus {
  reserved
  checked_in
  checked_out
  cancelled
  no_show
}
enum Gender {
  male 
  female
  other
}
enum DocumentType {
  reservation
  sale
  stock_adjustment
  payment
}
enum ContactType {
  customer 
  supplier
}
enum PaymentDirection {
  outgoing
  ingoing
}
enum AllocactionType {
  reservation
  sale
  purchase
}
enum TransactionType {
  reservation
  sale
  purchase
  payment
}
enum PaymentStatus {
  paid
  partially_paid
  due
}